{
  "name": "alaniz-creative",
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "scripts": {
    "build:client": "npx tsc --project tsconfig.client.json",
    "build:node": "npx tsc --project tsconfig.node.json",
    "build": "pnpm build:client && pnpm build:node && node lib/esbuild/esbuild.js --site",
    "watch:client": "npx tsc --watch --preserveWatchOutput --project tsconfig.client.json",
    "watch:node": "npx tsc --watch --preserveWatchOutput --project tsconfig.node.json",
    "watch:esbuild": "node scripts/watch.js",
    "start": "npm-run-all --parallel watch:node watch:client watch:esbuild",
    "lint:ts": "npx eslint .",
    "lint:scss": "stylelint 'src/**/*.scss'",
    "lint": "pnpm lint:ts && pnpm lint:scss",
    "wrangler:contact": "npx wrangler dev --config src/workers/Contact/wrangler.json",
    "wrangler:file": "npx wrangler dev --remote --config src/workers/File/wrangler.json",
    "wrangler:password": "npx wrangler dev --config src/workers/Password/wrangler.json",
    "wrangler:site": "npx wrangler dev --config wrangler.json",
    "wrangler:staging": "npx wrangler dev --config wrangler.json --env staging",
    "clean": "rm -rf node_modules/.cache/tsbuildinfo.* || true && rm -rf .cache || true && rm -rf site || true && rm -rf lib || true"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "uuid@>=13.0.0 <13.0.1": ">=13.0.1"
    }
  },
  "dependencies": {
    "@alanizcreative/formation": "0.0.3",
    "@alanizcreative/formation-static": "0.0.5",
    "@cloudflare/workers-types": "4.20260506.1",
    "@esbuild/linux-x64": "0.28.0",
    "@fullhuman/postcss-purgecss": "8.0.0",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/validator": "13.15.10",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "html-minifier-terser": "^7.2.0",
    "postcss": "^8.5.14",
    "postcss-modules": "^6.0.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "validator": "13.15.35"
  },
  "devDependencies": {
    "eslint": "10.3.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript-eslint": "8.59.2"
  },
  "optionalDependencies": {
    "nodemon": "3.1.14",
    "npm-run-all": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "browserslist": [
    "> 0.5%"
  ]
}
